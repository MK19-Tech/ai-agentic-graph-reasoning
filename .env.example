# ─────────────────────────────────────────────────────────────────────────────
# .env.example  –  copy to .env and fill in your real values
# ─────────────────────────────────────────────────────────────────────────────

# Required ────────────────────────────────────────────────────────────────────
# Get your key at https://console.groq.com  (starts with gsk_)
GROQ_API_KEY=gsk_YourGroqKeyHere

# Optional: override the default model
GROQ_MODEL=llama3-70b-8192

# Optional: web-search tool for agents
TAVILY_API_KEY=tvly-YourTavilyKeyHere

# Optional: LangSmith tracing
LANGSMITH_API_KEY=lsv2_YourLangSmithKeyHere
LANGCHAIN_TRACING_V2=false

# Optional: set to true to enforce strict gsk_ key format validation
GROQ_API_KEY_STRICT=false
